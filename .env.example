# AgentCordon — Environment Variables
#
# Copy this file to .env and customize as needed.
# All variables are optional — the server auto-generates secrets on first run.

# ── Server ──────────────────────────────────────────────────────────────────
AGTCRDN_PORT=3140                         # Server listen port
AGTCRDN_DB_PATH=./data/agent-cordon.db    # SQLite database path
AGTCRDN_MASTER_SECRET=                    # Master encryption key (auto-generated if empty)
AGTCRDN_ROOT_USERNAME=                    # Admin username (auto-generated if empty)
AGTCRDN_ROOT_PASSWORD=                    # Admin password (auto-generated, printed on first boot)
AGTCRDN_SEED_DEMO=true                    # Seed demo data on first boot
AGTCRDN_BASE_URL=                         # Server base URL (required for OAuth2 MCP flows)
AGTCRDN_SESSION_TTL=28800                 # Session TTL in seconds (default: 8 hours)

# ── Logging ─────────────────────────────────────────────────────────────────
AGTCRDN_LOG_LEVEL=warn                    # Logging level (trace, debug, info, warn, error)
AGTCRDN_LOG_FORMAT=json                   # Log output format (json or pretty)

# ── Proxy ───────────────────────────────────────────────────────────────────
AGTCRDN_PROXY_ALLOW_LOOPBACK=false        # Allow proxy to localhost targets (dev only, never in prod)

# ── OAuth ───────────────────────────────────────────────────────────────────
AGTCRDN_OAUTH_AUTH_CODE_TTL=300           # Authorization code TTL in seconds (default: 300)

# ── Broker ──────────────────────────────────────────────────────────────────
AGTCRDN_BROKER_PORT=3141                  # Broker daemon listen port (default: 3141)
AGTCRDN_BROKER_URL=                       # Override broker URL (e.g. http://localhost:3141)

# ── OAuth Dynamic Client Registration ───────────────────────────────────────
# Optional: label used in OAuth Dynamic Client Registration requests as `client_name`.
# Defaults to "AgentCordon" if not set. Useful when multiple AgentCordon instances
# register with the same provider (e.g., Notion, GitHub, Slack).
# AGTCRDN_INSTANCE_LABEL=

# ── MCP OAuth Apps ──────────────────────────────────────────────────────────
# OAuth app credentials (client_id / client_secret) for MCP servers are
# configured in Settings > MCP OAuth Apps in the web UI, NOT via env vars.
# They are stored encrypted in the database.
